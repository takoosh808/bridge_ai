PORT=8000
NODE_ENV=staging

DATABASE_URL=postgresql://bridge:bridge@postgres:5432/bridge
REDIS_URL=redis://redis:6379

WEBHOOK_SECRET=
WEBHOOK_SECRET_FILE=/run/secrets/webhook_secret

GITHUB_TOKEN=
GITHUB_TOKEN_FILE=/run/secrets/github_token

OPENAI_API_KEY=
OPENAI_API_KEY_FILE=/run/secrets/openai_api_key

ADMIN_API_TOKEN_HASH=
ADMIN_API_TOKEN_HASH_FILE=/run/secrets/admin_api_token_hash

ADMIN_API_TOKEN_PEPPER=
ADMIN_API_TOKEN_PEPPER_FILE=/run/secrets/admin_api_token_pepper

ADMIN_RATE_LIMIT_WINDOW_MS=60000
ADMIN_RATE_LIMIT_MAX=120
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000
WEBHOOK_RATE_LIMIT_MAX=300

DATA_RETENTION_DAYS=30
RETENTION_CLEANUP_INTERVAL_MINUTES=360
